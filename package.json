{
  "name": "payment-issue-processor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.12"
  },
  "description": "Payment issue processing service with AI-powered decision making",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "demo": "tsx src/demo.ts",
    "submit": "tsx src/submit.ts",
    "review": "tsx src/review.ts",
    "db:seed": "tsx src/seed.ts",
    "db:reset": "rm -f issues.db issues.db-wal issues.db-shm",
    "report": "tsx src/report.ts",
    "report:md": "tsx src/report.ts --out results.md",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.175",
    "better-sqlite3": "^12.10.0",
    "express": "^4.21.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
